{
  "name": "apexcss",
  "version": "0.3.7",
  "description": "Apex - A utility-first CSS framework with 500+ utility classes",
  "type": "module",
  "main": "dist/apex.css",
  "module": "dist/apex.css",
  "style": "dist/apex.css",
  "types": "./package.json",
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "docs/LLMs.txt"
  ],
  "exports": {
    ".": {
      "style": "./dist/apex.css"
    },
    "./base": {
      "style": "./dist/base.css"
    },
    "./themes": {
      "style": "./dist/themes.css"
    },
    "./utilities": {
      "style": "./dist/utilities.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "npm run config:build && npm run lint && vite build",
    "prepublishOnly": "npm run clean && npm run build",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "lint": "stylelint 'src/**/*.scss'",
    "clean": "rm -rf dist",
    "config:init": "node tools/config-builder.js --init",
    "config:build": "node tools/config-builder.js --config=apex.config.js",
    "config:watch": "node tools/config-builder.js --config=apex.config.js --watch",
    "test:unit": "mocha \"tests/unit/**/*.test.js\"",
    "test:coverage": "c8 --all --src=tools --exclude=tests/** --reporter=text --reporter=lcov mocha \"tests/unit/**/*.test.js\"",
    "test:e2e": "cd tests/e2e && npm run test:e2e",
    "test:e2e:ui": "cd tests/e2e && npm run test:e2e -- --ui",
    "test:e2e:install": "cd tests/e2e && npm install && npx playwright install --with-deps"
  },
  "keywords": [
    "css",
    "framework",
    "utility-first",
    "sass",
    "scss",
    "apexcss",
    "tailwind",
    "bootstrap-alternative"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chris-briddock/apex"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "autoprefixer": "^10.4.27",
    "c8": "^10.1.3",
    "mocha": "^11.7.5",
    "postcss": "^8.5.6",
    "postcss-preset-env": "^11.2.0",
    "postcss-scss": "^4.0.9",
    "sass": "^1.97.3",
    "sass-true": "^10.1.0",
    "stylelint": "^17.3.0",
    "stylelint-config-standard-scss": "17.0.0",
    "vite": "^7.3.1"
  }
}
